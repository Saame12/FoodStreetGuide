<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodStreetGuide.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FoodStreetGuide.Views">

    <TabBar>

        <ShellContent Title="Khám phá"
                      Icon="explore.png"
                      ContentTemplate="{DataTemplate views:ExplorePage}" />

        <ShellContent Title="Bản đồ"
                      Icon="map.png"
                      ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent Title="Tài khoản"
                      Icon="user.png"
                      ContentTemplate="{DataTemplate views:ProfilePage}" />

    </TabBar>

</Shell>
