<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodStreetGuide.Views.ExplorePage"
             Title="Khám phá">

    <VerticalStackLayout Padding="10">

        <Label Text="Địa điểm nổi bật"
               FontSize="22"
               FontAttributes="Bold"/>

        <CollectionView x:Name="placeList">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame CornerRadius="15"
                           Margin="5"
                           BackgroundColor="#f5f5f5">

                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18"/>
                            <Label Text="{Binding DescriptionVI}"
                                   LineBreakMode="TailTruncation"/>
                            <Button Text="Xem trên bản đồ"/>
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>