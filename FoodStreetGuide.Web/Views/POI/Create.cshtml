@model FoodStreetGuide.Application.DTOs.PoiCreateDto

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4>Thêm Địa Điểm Ẩm Thực Mới</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label class="form-label">Tên địa điểm</label>
                            <input asp-for="Name" class="form-control" placeholder="Ví dụ: Bánh Mì Phượng" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label class="form-label">Ngôn ngữ</label>
                            <select asp-for="Language" class="form-select">
                                <option value="vi">Tiếng Việt</option>
                                <option value="en">English</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group mb-3">
                            <label class="form-label">Vĩ độ (Lat)</label>
                            <input asp-for="Latitude" class="form-control" type="number" step="any" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group mb-3">
                            <label class="form-label">Kinh độ (Long)</label>
                            <input asp-for="Longitude" class="form-control" type="number" step="any" />
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label">Mô tả chi tiết</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="form-group mb-3">
                        <label>File Audio thuyết minh (.mp3)</label>
                        <input type="file" name="audioFile" class="form-control" accept=".mp3" />
                    </div>
                    <div class="form-group mb-3">
                        <label>Hình ảnh địa điểm</label>
                        <input type="file" name="imageFiles" class="form-control" multiple accept="image/*" />
                    </div>
                    <button type="submit" class="btn btn-primary">Lưu và Upload</button>
                </form>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">Lưu địa điểm</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}