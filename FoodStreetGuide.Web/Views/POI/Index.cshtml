@model IEnumerable<FoodStreetGuide.Application.DTOs.PoiDto>

<div class="container">
    <h2 class="mt-4">Quản lý địa điểm FoodStreet</h2>
    <a asp-action="Create" class="btn btn-success mb-3">Thêm địa điểm mới</a>

    <table class="table table-bordered">
        <thead class="thead-dark">
            <tr>
                <th>Tên địa điểm</th>
                <th>Tọa độ</th>
                <th>Ngôn ngữ</th>
                <th>Ưu tiên</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Latitude, @item.Longitude</td>
                    <td>@item.Language</td>
                    <td>@item.Priority</td>
                </tr>
            }
        </tbody>
    </table>
</div>